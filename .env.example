# Neon Postgres connection string
DATABASE_URL=

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_BOT_USERNAME=
NEXT_PUBLIC_APP_URL=

# Vercel Cron secret (random string)
CRON_SECRET=

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TEMPLATE_NAME=order_ready
# Reminder templates now live in the DB (reminder_templates table); no single env template.

# Default bread price (used when bread_type has no price set)
DEFAULT_BREAD_PRICE=35

# Public site: which group's bakery is served at the root URL "/"
PUBLIC_SITE_GROUP_ID=1

# Telegram chat to notify on each successful production deploy.
# Optional — defaults to the owner of PUBLIC_SITE_GROUP_ID if unset.
DEPLOY_NOTIFY_CHAT_ID=

# Vercel Blob (image library for the public site) — provisioned by Vercel
BLOB_READ_WRITE_TOKEN=
